# =====================================================
# HEADERS - Netlify Configuration
# Optimización Performance & Security
# =====================================================

# HTML - Sin caché para contenido dinámico
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# CSS - Caché agresivo con immutable (incluye subdirectorios)
/css/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/css/core/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/css/components/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/css/layouts/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/css/utils/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# JavaScript - Caché agresivo con immutable (incluye subdirectorios)
/js/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/js/components/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/config/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Imágenes - Caché agresivo (incluyendo subdirectorios)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/assets/images/Desktop/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/assets/images/mobile/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff
  X-Content-Type-Options: nosniff

# Fuentes - Caché agresivo con CORS
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/*.otf
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/*.eot
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

# Archivos de datos
/*.json
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

/*.xml
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

# Seguridad global para todos los archivos
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://formspree.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://formspree.io; frame-ancestors 'none'

